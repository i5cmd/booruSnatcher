<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Kartian_s_Booru_Snatcher.BooruConfig"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kartian_s_Booru_Snatcher"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BooruConfig">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock FontSize="30" Margin="17 10 10 10" FontWeight="Bold">Configurations</TextBlock>
            <TextBox PlaceholderText="Booru name..." x:Name="BooruName" Margin="10" Width="350"></TextBox>
            <TextBlock FontSize="12" FontWeight="Light" TextWrapping="WrapWholeWords" Margin="17 0 0 0">The booru engine type should be shown on the main page of the site.</TextBlock>
            <ComboBox x:Name="BooruEngineComboBox" Margin="17 3 10 10" SelectedValue="Gelbooru" Width="350">
                <x:String>Gelbooru</x:String>
                <x:String>Danbooru</x:String>
                <x:String>Moebooru</x:String>
            </ComboBox>
            <TextBox PlaceholderText="Url... (e.g. https://safebooru.org/)" x:Name="BooruUrl" Margin="10" Width="350"></TextBox>
            <TextBlock FontSize="12" FontWeight="Light" TextWrapping="WrapWholeWords" Margin="17 0 10 0">If the snatching doesn't work, the site might need your account's API and User ID. Put it only when snatching doesn't work.</TextBlock>
            <TextBox PlaceholderText="API key..." x:Name="ApiKey" Margin="10 3 10 10" Width="350"></TextBox>
            <TextBox PlaceholderText="User Id or Login..." x:Name="UserId" Margin="10" Width="350"></TextBox>
            <Button Content="Save configuration" Style="{StaticResource AccentButtonStyle}" Margin="17 10 10 10" Width="350" Click="Save_Click"></Button>
        </StackPanel>
        <ListView x:Name="BooruList" ItemsSource="{x:Bind configs}" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:BooruConfiguration">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="Medium" Text="{x:Bind Name}" Margin="4 0"></TextBlock>
                        <TextBlock FontSize="12" FontWeight="Light" Text="{x:Bind Engine}" Margin="4 0"></TextBlock>
                        <HyperlinkButton FontSize="8" FontWeight="Light" Padding="0" Content="{x:Bind Url}" Margin="4 0"></HyperlinkButton>
                        <StackPanel Orientation="Horizontal" DataContext="{x:Bind}">
                            <Button Content="Delete configuration" Click="DeleteConfig_Click" Margin="4"></Button>
                            <Button Content="Use this configuration" Click="UseConfig_Click" Margin="4"></Button>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
